{
  "name": "Opencode Persistence",
  "id": "opencode-persistence",
  "version": "1.0.0",
  "documentationURL": "https://github.com/ultranomic/devcontainer-features/tree/main/src/opencode-persistence",
  "description": "Avoid extra logins from the Opencode by preserving the `~/.config/opencode` folder across container instances.",
  "options": {},
  "mounts": [
    {
      "source": "${devcontainerId}-opencode",
      "target": "/dc/opencode",
      "type": "volume"
    }
  ],
  "installsAfter": [
    "ghcr.io/devcontainer-community/devcontainer-features/opencode.ai",
    "ghcr.io/jsburckhardt/devcontainer-features/opencode"
  ],
  "onCreateCommand": {
    "opencode-persistence-setup": "/usr/local/share/opencode-persistence/scripts/oncreate.sh"
  }
}
